---
// src/pages/index.astro  ← your main landing page
import AnimalSelector from '../components/Animalselector.astro';
import '../styles/global.css';

// Detect lang from cookie or browser, default to 'en'
// You can extend this later with i18n middleware
const lang = 'en';
---

<!doctype html>
<html lang={lang} class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pet care guide</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inria+Sans:ital,wght@0,300;0,400;0,700;1,300;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="h-full m-0 p-0 font-['Inria_Sans',sans-serif]">
    <AnimalSelector lang={lang} />
  </body>
</html>